@model PagedResult<Expense>

@if (Model != null && Model.Items.Any())
{
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.Description</td>
            <td>@item.Amount.ToString("0.00")</td>
            <td>@item.Category</td>
            <td>@item.Date.ToString("yyyy-MM-dd")</td>
            <td class="d-flex gap-1">
                <a asp-controller="Expenses" asp-action="UpdateItem" asp-route-itemId="@item.Id" class="btn btn-sm btn-primary">
                    Edit <i class="bi bi-pencil"></i>
                </a>
                <button type="button"
                        class="btn btn-sm btn-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#deleteModal"
                        data-id="@item.Id"
                        data-description="@item.Description">
                    Delete <i class="bi bi-trash"></i>
                </button>
            </td>
        </tr>
    }
    <tr>
        <td colspan="5" class="border-0 p-0">
            <nav>
                <ul class="pagination justify-content-center mt-3">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" href="#"
                               onclick="loadTable(activeYear, activeMonth, @(Model.PageNumber - 1)); return false;">
                            Previous
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link" href="#"
                                   onclick="loadTable(activeYear, activeMonth, @i); return false;">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" href="#"
                               onclick="loadTable(activeYear, activeMonth, @(Model.PageNumber + 1)); return false;">
                            Next
                        </a>
                    </li>
                </ul>
            </nav>
        </td>
    </tr>
}
else
{
    <tr>
        <td colspan="5" class="text-center text-muted py-4">
            <i class="bi bi-inbox" style="font-size: 2rem;"></i>
            <div class="mt-2">No Records Available</div>
            <small>No expenses found for the selected period.</small>
        </td>
    </tr>
}